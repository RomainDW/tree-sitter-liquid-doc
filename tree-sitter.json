{
  "grammars": [
    {
      "name": "liquid-doc",
      "camelcase": "LiquidDoc",
      "scope": "source.liquid-doc",
      "path": ".",
      "file-types": [],
      "injection-regex": "liquid-doc"
    }
  ],
  "metadata": {
    "version": "0.1.0",
    "license": "MIT",
    "description": "Tree-sitter grammar for Liquid doc comments",
    "links": {
      "repository": "https://github.com/tree-sitter/tree-sitter-liquid-doc"
    }
  },
  "bindings": {
    "c": true,
    "go": true,
    "node": true,
    "python": true,
    "rust": true,
    "swift": true
  }
}
