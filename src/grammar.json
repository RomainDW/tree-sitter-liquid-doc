{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/grammar.schema.json",
  "name": "liquid_doc",
  "rules": {
    "document": {
      "type": "REPEAT",
      "content": {
        "type": "CHOICE",
        "members": [
          {
            "type": "SYMBOL",
            "name": "description"
          },
          {
            "type": "SYMBOL",
            "name": "param_tag"
          },
          {
            "type": "SYMBOL",
            "name": "example_tag"
          },
          {
            "type": "SYMBOL",
            "name": "_newline"
          },
          {
            "type": "SYMBOL",
            "name": "_whitespace"
          }
        ]
      }
    },
    "description": {
      "type": "TOKEN",
      "content": {
        "type": "SEQ",
        "members": [
          {
            "type": "PATTERN",
            "value": "[^@\\n\\s]"
          },
          {
            "type": "PATTERN",
            "value": "[^\\n]*"
          }
        ]
      }
    },
    "param_tag": {
      "type": "PREC_RIGHT",
      "value": 0,
      "content": {
        "type": "SEQ",
        "members": [
          {
            "type": "ALIAS",
            "content": {
              "type": "STRING",
              "value": "@param"
            },
            "named": true,
            "value": "tag_name"
          },
          {
            "type": "SYMBOL",
            "name": "_whitespace"
          },
          {
            "type": "SYMBOL",
            "name": "type"
          },
          {
            "type": "SYMBOL",
            "name": "_whitespace"
          },
          {
            "type": "SYMBOL",
            "name": "param_name"
          },
          {
            "type": "CHOICE",
            "members": [
              {
                "type": "SEQ",
                "members": [
                  {
                    "type": "SYMBOL",
                    "name": "_whitespace"
                  },
                  {
                    "type": "STRING",
                    "value": "-"
                  },
                  {
                    "type": "SYMBOL",
                    "name": "_whitespace"
                  },
                  {
                    "type": "SYMBOL",
                    "name": "param_description"
                  }
                ]
              },
              {
                "type": "BLANK"
              }
            ]
          }
        ]
      }
    },
    "type": {
      "type": "TOKEN",
      "content": {
        "type": "SEQ",
        "members": [
          {
            "type": "STRING",
            "value": "{"
          },
          {
            "type": "PATTERN",
            "value": "[^}]+"
          },
          {
            "type": "STRING",
            "value": "}"
          }
        ]
      }
    },
    "param_name": {
      "type": "CHOICE",
      "members": [
        {
          "type": "PATTERN",
          "value": "[a-zA-Z_][a-zA-Z0-9_]*"
        },
        {
          "type": "TOKEN",
          "content": {
            "type": "SEQ",
            "members": [
              {
                "type": "STRING",
                "value": "["
              },
              {
                "type": "PATTERN",
                "value": "[a-zA-Z_][a-zA-Z0-9_]*"
              },
              {
                "type": "STRING",
                "value": "]"
              }
            ]
          }
        }
      ]
    },
    "param_description": {
      "type": "PATTERN",
      "value": "[^\\n]+"
    },
    "example_tag": {
      "type": "PREC_RIGHT",
      "value": 0,
      "content": {
        "type": "SEQ",
        "members": [
          {
            "type": "ALIAS",
            "content": {
              "type": "STRING",
              "value": "@example"
            },
            "named": true,
            "value": "tag_name"
          },
          {
            "type": "REPEAT",
            "content": {
              "type": "SEQ",
              "members": [
                {
                  "type": "SYMBOL",
                  "name": "_newline"
                },
                {
                  "type": "CHOICE",
                  "members": [
                    {
                      "type": "SYMBOL",
                      "name": "example_content"
                    },
                    {
                      "type": "BLANK"
                    }
                  ]
                }
              ]
            }
          }
        ]
      }
    },
    "example_content": {
      "type": "PATTERN",
      "value": "[ \\t]+[^\\n]+"
    },
    "_newline": {
      "type": "PATTERN",
      "value": "\\n"
    },
    "_whitespace": {
      "type": "PATTERN",
      "value": "[ \\t]+"
    }
  },
  "extras": [],
  "conflicts": [],
  "precedences": [],
  "externals": [],
  "inline": [],
  "supertypes": []
}
